---
/**
 * NewsPost.astro — Layout for individual news articles.
 */
import Base from './Base.astro';
import { articleJsonLd, buildSeoProps, SITE_URL } from '@utils/seo';
import { formatDateLong, formatDateISO } from '@utils/dates';
import { getActiveTheme } from '@utils/theme';

interface Props {
  title: string;
  publishDate: Date;
  excerpt?: string;
  featuredImage?: string;
  slug: string;
}

const { title, publishDate, excerpt, featuredImage, slug } = Astro.props;
const theme = await getActiveTheme();

const canonicalUrl = `${SITE_URL}/nyheter/${slug}/`;

const seoProps = buildSeoProps({
  title,
  description: excerpt,
  canonical: canonicalUrl,
  ogImage: featuredImage,
  ogType: 'article',
  publishDate,
});

const jsonLd = [
  articleJsonLd({
    title,
    url: canonicalUrl,
    publishDate,
    description: excerpt,
    imageUrl: featuredImage,
  }),
];
---

<Base {...seoProps} jsonLd={jsonLd}>
  <article class="container-content py-10 lg:py-16 max-w-3xl">
    <!-- Back link -->
    <a
      href="/nyheter/"
      class:list={[
        'inline-flex items-center gap-1 text-sm mb-6 transition-colors',
        theme === 'faithful'
          ? 'text-classic-500 hover:text-classic-700'
          : 'text-forest-600 hover:text-forest-800',
      ]}
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      Tillbaka till nyheter
    </a>

    <!-- Featured image -->
    {featuredImage && (
      <div class="w-full aspect-video overflow-hidden rounded-xl mb-8">
        <img
          src={featuredImage}
          alt={title}
          class="w-full h-full object-cover"
          loading="eager"
        />
      </div>
    )}

    <!-- Article header -->
    <header class="mb-8">
      <time
        datetime={formatDateISO(publishDate)}
        class="text-sm text-neutral-500 font-medium"
      >
        {formatDateLong(publishDate)}
      </time>
      <h1 class:list={['text-3xl sm:text-4xl font-bold text-neutral-900 mt-2 leading-tight', theme === 'faithful' ? '' : 'font-display']}>
        {title}
      </h1>
      {excerpt && (
        <p class="text-lg text-neutral-600 mt-4 leading-relaxed">
          {excerpt}
        </p>
      )}
    </header>

    <!-- Article body -->
    <div class="prose-club">
      <slot />
    </div>

    <!-- Bottom nav -->
    <div class="mt-12 pt-8 border-t border-neutral-200">
      <a href="/nyheter/" class="btn-secondary">
        ← Fler nyheter
      </a>
    </div>
  </article>
</Base>
