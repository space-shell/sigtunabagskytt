---
/**
 * Individual discipline page — /prova-pa/grenar/[slug]/
 */
import Page from '@layouts/Page.astro';
import { buildSeoProps, breadcrumbJsonLd, SITE_URL } from '@utils/seo';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const disciplines = await getCollection('disciplines');
  return disciplines.map((disc) => ({
    params: { slug: disc.slug },
    props: { disc },
  }));
}

const { disc } = Astro.props;
const { Content } = await render(disc);

const canonicalUrl = `${SITE_URL}/prova-pa/grenar/${disc.slug}/`;

const seoProps = buildSeoProps({
  title: disc.data.title,
  description: disc.data.shortDescription,
  canonical: canonicalUrl,
});

const jsonLd = [
  breadcrumbJsonLd([
    { name: 'Hem', url: `${SITE_URL}/` },
    { name: 'Prova på', url: `${SITE_URL}/prova-pa/` },
    { name: 'Grenar', url: `${SITE_URL}/prova-pa/grenar/` },
    { name: disc.data.title, url: canonicalUrl },
  ]),
];
---

<Page
  {...seoProps}
  title={disc.data.title}
  breadcrumb={[
    { label: 'Prova på', href: '/prova-pa/' },
    { label: 'Grenar', href: '/prova-pa/grenar/' },
  ]}
  jsonLd={jsonLd}
>
  <p class="text-lg text-neutral-600 leading-relaxed mb-8 max-w-2xl">
    {disc.data.shortDescription}
  </p>

  <div class="prose-club max-w-2xl">
    <Content />
  </div>

  <div class="mt-10 flex flex-col sm:flex-row gap-3">
    <a href="/prova-pa/" class="btn-primary">
      Prova på bågskyttning
    </a>
    <a href="/prova-pa/grenar/" class="btn-secondary">
      ← Alla grenar
    </a>
  </div>
</Page>
