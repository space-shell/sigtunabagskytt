---
/**
 * Hem (Home page)
 */
import Base from '@layouts/Base.astro';
import { buildSeoProps, sportsClubJsonLd, SITE_URL } from '@utils/seo';
import { CLUB_NAME, CLUB_EMAIL_HREF } from '@utils/constants';
import { getCollection } from 'astro:content';
import { formatDateShort } from '@utils/dates';

const seoProps = buildSeoProps({
  title: `${CLUB_NAME} – Bågskyttning i Märsta, Sigtuna`,
  description:
    'Välkommen till Sigtuna Bågskytteklubb. Prova på bågskyttning för nybörjare – recurve, compound och långbåge. Träning för alla åldrar från 10 år.',
  canonical: SITE_URL,
});

// Get the 3 most recent news posts
const allNews = await getCollection('news', ({ data }) => !data.draft);
const recentNews = allNews
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const jsonLd = [sportsClubJsonLd()];
---

<Base {...seoProps} jsonLd={jsonLd}>

  <!-- ── Hero ─────────────────────────────────────────────────────────────── -->
  <section class="relative bg-forest-900 text-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-forest-900 via-forest-800 to-forest-950 opacity-90"></div>
    <!-- Hero background image -->
    <div class="absolute inset-0">
      <img
        src="/images/hero-home.jpg"
        alt=""
        class="w-full h-full object-cover opacity-30"
        loading="eager"
        fetchpriority="high"
      />
    </div>

    <div class="relative container-content py-20 sm:py-28 lg:py-36">
      <div class="max-w-2xl">
        <p class="text-bark-400 font-semibold text-sm uppercase tracking-wider mb-3">
          Grundad 1979 · Märsta, Sigtuna
        </p>
        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight mb-6">
          Bågskyttning
          <span class="text-bark-400 block">för alla.</span>
        </h1>
        <p class="text-lg sm:text-xl text-forest-200 leading-relaxed mb-8 max-w-xl">
          Välkommen till Sigtuna Bågskytteklubb. Vi erbjuder träning i recurve, compound och
          långbåge för nybörjare och erfarna skyttar från 10 år.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/prova-pa/" class="btn-accent text-base px-8 py-3">
            Prova på bågskyttning
          </a>
          <a href="/om-oss/medlemskap/" class="btn-secondary border-forest-400 text-forest-200 hover:bg-forest-800 text-base px-8 py-3">
            Bli medlem
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Value Props ───────────────────────────────────────────────────────── -->
  <section class="bg-parchment-50 py-16">
    <div class="container-content">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          {
            icon: '🎯',
            title: 'Alla nivåer',
            text: 'Från total nybörjare till tävlingsskytt. Vi välkomnar alla från 10 år.',
          },
          {
            icon: '🏹',
            title: 'Prova på gratis*',
            text: '3 provtillfällen för 100 kr. All utrustning ingår – ta med dig själv.',
          },
          {
            icon: '🌲',
            title: 'Utomhus & inomhus',
            text: 'Träning hela året – sommar på Rävsta skjutbana, vinter i Eddaskolan.',
          },
          {
            icon: '🏆',
            title: 'Tävlingsverksamhet',
            text: 'Vi arrangerar Thors 3D och deltar i distriktsmästerskap.',
          },
        ].map(({ icon, title, text }) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-neutral-100">
            <div class="text-3xl mb-3" aria-hidden="true">{icon}</div>
            <h3 class="font-display font-bold text-lg text-neutral-900 mb-2">{title}</h3>
            <p class="text-neutral-600 text-sm leading-relaxed">{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Latest News ───────────────────────────────────────────────────────── -->
  {recentNews.length > 0 && (
    <section class="py-16">
      <div class="container-content">
        <div class="flex items-end justify-between mb-8">
          <div>
            <h2 class="section-heading">Senaste nytt</h2>
            <p class="section-subheading">Nyheter och uppdateringar från klubben</p>
          </div>
          <a href="/nyheter/" class="text-forest-600 hover:text-forest-800 font-medium text-sm transition-colors hidden sm:block">
            Alla nyheter →
          </a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {recentNews.map((post) => (
            <article class="card group">
              {post.data.featuredImage && (
                <div class="aspect-video overflow-hidden">
                  <img
                    src={post.data.featuredImage as unknown as string}
                    alt={post.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="p-5">
                <time class="text-xs text-neutral-500 font-medium">
                  {formatDateShort(post.data.publishDate)}
                </time>
                <h3 class="font-display font-bold text-lg mt-1 mb-2 leading-tight group-hover:text-forest-700 transition-colors">
                  <a href={`/nyheter/${post.slug}/`} class="stretched-link">
                    {post.data.title}
                  </a>
                </h3>
                {post.data.excerpt && (
                  <p class="text-neutral-600 text-sm leading-relaxed line-clamp-3">
                    {post.data.excerpt}
                  </p>
                )}
              </div>
            </article>
          ))}
        </div>

        <div class="mt-6 sm:hidden">
          <a href="/nyheter/" class="btn-secondary w-full text-center">Alla nyheter</a>
        </div>
      </div>
    </section>
  )}

  <!-- ── Prova på CTA ──────────────────────────────────────────────────────── -->
  <section class="bg-forest-700 text-white py-16">
    <div class="container-content text-center">
      <h2 class="font-display text-3xl sm:text-4xl font-bold mb-4">
        Nyfiken på bågskyttning?
      </h2>
      <p class="text-forest-200 text-lg max-w-xl mx-auto mb-8">
        Kom och prova på tre gånger för bara 100 kr. Första måndagen varje månad, kl 18:00.
        All utrustning ingår.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/prova-pa/" class="btn-accent px-8 py-3 text-base">
          Läs mer om Prova på
        </a>
        <a href={CLUB_EMAIL_HREF + '?subject=Prova+på+bågskyttning'} class="btn-secondary border-forest-400 text-forest-200 hover:bg-forest-600 px-8 py-3 text-base">
          Skicka e-post
        </a>
      </div>
      <p class="text-xs text-forest-400 mt-4">* 100 kr dras av om du väljer att bli medlem</p>
    </div>
  </section>

  <!-- ── Location Summary ──────────────────────────────────────────────────── -->
  <section class="py-16 bg-parchment-50">
    <div class="container-content">
      <h2 class="section-heading text-center mb-2">Hitta oss</h2>
      <p class="section-subheading text-center mb-10">Vi tränar på två platser beroende på säsong</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-2xl mx-auto">
        <div class="bg-white rounded-xl p-6 border border-neutral-200 shadow-sm">
          <p class="text-forest-600 font-semibold text-sm uppercase tracking-wider mb-1">Sommar (maj–dec)</p>
          <h3 class="font-display font-bold text-lg mb-1">Rävsta skjutbana</h3>
          <p class="text-neutral-600 text-sm">Rävstvägen 110, Märsta</p>
          <a
            href="/kontakt/hitta-till-oss/"
            class="inline-block mt-3 text-sm text-forest-600 hover:text-forest-800 font-medium transition-colors"
          >
            Vägbeskrivning →
          </a>
        </div>

        <div class="bg-white rounded-xl p-6 border border-neutral-200 shadow-sm">
          <p class="text-forest-600 font-semibold text-sm uppercase tracking-wider mb-1">Vinter (jan–apr)</p>
          <h3 class="font-display font-bold text-lg mb-1">Eddaskolan</h3>
          <p class="text-neutral-600 text-sm">Märsta</p>
          <a
            href="/kontakt/hitta-till-oss/"
            class="inline-block mt-3 text-sm text-forest-600 hover:text-forest-800 font-medium transition-colors"
          >
            Vägbeskrivning →
          </a>
        </div>
      </div>
    </div>
  </section>

</Base>
