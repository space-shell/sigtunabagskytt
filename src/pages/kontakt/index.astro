---
/**
 * Kontakt (Contact) page with contact form
 */
import Page from '@layouts/Page.astro';
import { buildSeoProps, breadcrumbJsonLd, SITE_URL } from '@utils/seo';
import { CLUB_EMAIL, CLUB_EMAIL_HREF, CLUB_PHONE, CLUB_PHONE_HREF, FACEBOOK_URL } from '@utils/constants';

const seoProps = buildSeoProps({
  title: 'Kontakt',
  description: 'Kontakta Sigtuna Bågskytteklubb – via e-post, telefon eller kontaktformuläret.',
  canonical: `${SITE_URL}/kontakt/`,
});

const jsonLd = [
  breadcrumbJsonLd([
    { name: 'Hem', url: `${SITE_URL}/` },
    { name: 'Kontakt', url: `${SITE_URL}/kontakt/` },
  ]),
];
---

<Page
  {...seoProps}
  title="Kontakt"
  breadcrumb={[]}
  jsonLd={jsonLd}
>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

    <!-- Contact info -->
    <div>
      <p class="text-neutral-600 leading-relaxed mb-8">
        Har du frågor om bågskyttning, prova på eller klubben? Vi svarar gärna!
      </p>

      <div class="space-y-5 mb-8">
        <div class="flex items-start gap-3">
          <div class="w-8 h-8 bg-forest-100 rounded-full flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-4 h-4 text-forest-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wider text-neutral-500 mb-0.5">E-post</p>
            <a href={CLUB_EMAIL_HREF} class="text-forest-700 hover:text-forest-900 font-medium transition-colors">
              {CLUB_EMAIL}
            </a>
          </div>
        </div>

        <div class="flex items-start gap-3">
          <div class="w-8 h-8 bg-forest-100 rounded-full flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-4 h-4 text-forest-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wider text-neutral-500 mb-0.5">Telefon</p>
            <a href={CLUB_PHONE_HREF} class="text-forest-700 hover:text-forest-900 font-medium transition-colors">
              {CLUB_PHONE}
            </a>
          </div>
        </div>

        <div class="flex items-start gap-3">
          <div class="w-8 h-8 bg-forest-100 rounded-full flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-4 h-4 text-forest-700" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wider text-neutral-500 mb-0.5">Facebook</p>
            <a
              href={FACEBOOK_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="text-forest-700 hover:text-forest-900 font-medium transition-colors"
            >
              Sigtuna Bågskytteklubb
            </a>
          </div>
        </div>
      </div>

      <div class="bg-parchment-50 border border-neutral-200 rounded-xl p-5">
        <h2 class="font-display font-bold text-base mb-2">Hitta till oss</h2>
        <p class="text-sm text-neutral-600 mb-3">
          Vi tränar på två platser beroende på säsong.
        </p>
        <a href="/kontakt/hitta-till-oss/" class="text-sm text-forest-600 hover:text-forest-800 font-medium transition-colors">
          Vägbeskrivning och kartor →
        </a>
      </div>
    </div>

    <!-- Contact form -->
    <div>
      <h2 class="font-display font-bold text-xl mb-5">Skicka ett meddelande</h2>
      <form id="contact-form" class="space-y-4" novalidate>
        <div>
          <label for="name" class="block text-sm font-medium text-neutral-700 mb-1">
            Namn <span class="text-red-500" aria-hidden="true">*</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            autocomplete="name"
            class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm
                   focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-forest-500
                   placeholder:text-neutral-400"
            placeholder="Ditt namn"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-neutral-700 mb-1">
            E-post <span class="text-red-500" aria-hidden="true">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm
                   focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-forest-500
                   placeholder:text-neutral-400"
            placeholder="din@epost.se"
          />
        </div>

        <div>
          <label for="subject" class="block text-sm font-medium text-neutral-700 mb-1">Ämne</label>
          <input
            type="text"
            id="subject"
            name="subject"
            class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm
                   focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-forest-500
                   placeholder:text-neutral-400"
            placeholder="T.ex. Fråga om Prova på"
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-neutral-700 mb-1">
            Meddelande <span class="text-red-500" aria-hidden="true">*</span>
          </label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            class="w-full rounded-md border border-neutral-300 px-3 py-2 text-sm
                   focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-forest-500
                   placeholder:text-neutral-400 resize-y"
            placeholder="Ditt meddelande..."
          ></textarea>
        </div>

        <!-- Status messages -->
        <div id="form-error" class="hidden text-sm text-red-700 bg-red-50 border border-red-200 rounded-md px-4 py-3" role="alert"></div>
        <div id="form-success" class="hidden text-sm text-green-700 bg-green-50 border border-green-200 rounded-md px-4 py-3" role="status">
          Tack för ditt meddelande! Vi återkommer så snart vi kan.
        </div>

        <button type="submit" id="submit-btn" class="btn-primary w-full">
          Skicka meddelande
        </button>
      </form>
    </div>

  </div>
</Page>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const errorDiv = document.getElementById('form-error') as HTMLDivElement | null;
  const successDiv = document.getElementById('form-success') as HTMLDivElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !submitBtn || !errorDiv || !successDiv) return;

    // Hide previous messages
    errorDiv.classList.add('hidden');
    successDiv.classList.add('hidden');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Skickar...';

    const data = {
      name: (form.querySelector('#name') as HTMLInputElement).value.trim(),
      email: (form.querySelector('#email') as HTMLInputElement).value.trim(),
      subject: (form.querySelector('#subject') as HTMLInputElement).value.trim(),
      message: (form.querySelector('#message') as HTMLTextAreaElement).value.trim(),
      turnstileToken: 'dev-token', // Turnstile widget token would go here
    };

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const result = await res.json() as { success: boolean; error?: string };

      if (result.success) {
        successDiv.classList.remove('hidden');
        form.reset();
      } else {
        errorDiv.textContent = result.error ?? 'Något gick fel. Försök igen.';
        errorDiv.classList.remove('hidden');
      }
    } catch {
      errorDiv.textContent = 'Kunde inte skicka meddelandet. Kontrollera din internetanslutning.';
      errorDiv.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Skicka meddelande';
    }
  });
</script>
