---
import { NAV_ITEMS, CLUB_PHONE, CLUB_PHONE_HREF } from '@utils/constants';

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="bg-white border-b border-gray-200">
  <!-- Top utility bar -->
  <div class="bg-classic-500 text-white text-sm">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-9">
      <a
        href={CLUB_PHONE_HREF}
        class="flex items-center gap-1.5 text-white/90 hover:text-white transition-colors"
      >
        <!-- Phone icon -->
        <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {CLUB_PHONE}
      </a>
      <a href="/kontakt/hitta-till-oss/" class="text-white/90 hover:text-white transition-colors">
        Hitta hit
      </a>
    </div>
  </div>

  <!-- Main header: logo + nav -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">

      <!-- Logo -->
      <a href="/" aria-label="Sigtuna Bågskytteklubb – Startsida">
        <img
          src="/images/sbk-logo-original.png"
          alt="Sigtuna Bågskytteklubb"
          width="80"
          height="79"
          class="h-16 w-auto"
        />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-0" aria-label="Huvudnavigation">
        {NAV_ITEMS.map((item) => (
          <div class="relative group">
            {item.children ? (
              <>
                <button
                  class:list={[
                    'flex items-center gap-1 px-4 py-2 text-sm font-medium transition-colors border-b-2',
                    isActive(item.href)
                      ? 'text-classic-500 border-classic-500'
                      : 'text-gray-700 border-transparent hover:text-classic-500 hover:border-classic-500',
                  ]}
                  aria-expanded="false"
                  aria-haspopup="true"
                >
                  {item.label}
                  <svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
                <!-- Dropdown -->
                <div class="absolute top-full left-0 min-w-[200px] py-1 bg-white shadow-md border border-gray-100
                            opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
                  <a
                    href={item.href}
                    class:list={[
                      'block px-4 py-2.5 text-sm transition-colors hover:bg-classic-50 hover:text-classic-600',
                      isActive(item.href) ? 'text-classic-600 font-medium' : 'text-gray-700',
                    ]}
                  >
                    Översikt
                  </a>
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class:list={[
                        'block px-4 py-2.5 text-sm transition-colors hover:bg-classic-50 hover:text-classic-600',
                        isActive(child.href) ? 'text-classic-600 font-medium' : 'text-gray-700',
                      ]}
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </>
            ) : (
              <a
                href={item.href}
                class:list={[
                  'block px-4 py-2 text-sm font-medium transition-colors border-b-2',
                  isActive(item.href)
                    ? 'text-classic-500 border-classic-500'
                    : 'text-gray-700 border-transparent hover:text-classic-500 hover:border-classic-500',
                ]}
              >
                {item.label}
              </a>
            )}
          </div>
        ))}
      </nav>

      <!-- Mobile menu toggle -->
      <details class="lg:hidden group">
        <summary
          class="list-none flex items-center justify-center w-10 h-10 text-gray-700 hover:text-classic-500 cursor-pointer"
          aria-label="Öppna meny"
        >
          <svg class="w-6 h-6 group-open:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="w-6 h-6 hidden group-open:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </summary>
        <!-- Mobile dropdown -->
        <div class="absolute left-0 right-0 bg-white border-b border-gray-200 shadow-lg px-4 py-3 space-y-0.5 z-50">
          {NAV_ITEMS.map((item) => (
            <div>
              <a
                href={item.href}
                class:list={[
                  'block px-3 py-2.5 text-base font-medium transition-colors',
                  isActive(item.href)
                    ? 'text-classic-600 bg-classic-50'
                    : 'text-gray-800 hover:text-classic-600 hover:bg-classic-50',
                ]}
              >
                {item.label}
              </a>
              {item.children?.map((child) => (
                <a
                  href={child.href}
                  class:list={[
                    'block px-6 py-2 text-sm transition-colors',
                    isActive(child.href)
                      ? 'text-classic-600 bg-classic-50'
                      : 'text-gray-600 hover:text-classic-600 hover:bg-classic-50',
                  ]}
                >
                  {child.label}
                </a>
              ))}
            </div>
          ))}
        </div>
      </details>

    </div>
  </div>
</header>
