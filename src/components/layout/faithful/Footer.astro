---
import { CLUB_EMAIL, CLUB_EMAIL_HREF, CLUB_PHONE_HREF, FACEBOOK_URL } from '@utils/constants';

const currentYear = new Date().getFullYear();
---

<footer class="bg-[#040404] text-gray-300">

  <!-- Main footer columns -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-10">

      <!-- Contact column -->
      <div>
        <h2 class="text-lg font-bold text-white mb-1">Har du frågor?</h2>
        <p class="text-sm text-gray-400 mb-4">Hör av dig till oss</p>
        <a
          href={CLUB_EMAIL_HREF}
          class="text-classic-400 hover:text-classic-300 hover:underline text-sm break-all"
        >
          {CLUB_EMAIL}
        </a>
      </div>

      <!-- Locations column -->
      <div>
        <h2 class="text-lg font-bold text-white mb-4">Hitta till oss</h2>

        <div class="mb-5">
          <h3 class="font-semibold text-gray-200 mb-1">Klubbhuset i Rävsta</h3>
          <p class="text-sm text-gray-400 leading-relaxed">
            Under sommaren håller vi träningarna på vårt skjutfält i Rävsta.
            Adressen är Rävstvägen 110, Märsta.
          </p>
        </div>

        <div>
          <h3 class="font-semibold text-gray-200 mb-1">Eddaskolan i Valsta</h3>
          <p class="text-sm text-gray-400 leading-relaxed">
            Under vinterhalvåret håller vi till i Eddaskolans gymnastiksal i Märsta.
          </p>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-gray-800">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-gray-500">&copy; {currentYear} Alla rättigheter reserverade</p>

      <!-- Social/contact icons -->
      <ul class="flex items-center gap-4">
        <li>
          <a href={CLUB_PHONE_HREF} class="text-gray-500 hover:text-classic-400 transition-colors" aria-label="Ring oss">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </a>
        </li>
        <li>
          <a href={CLUB_EMAIL_HREF} class="text-gray-500 hover:text-classic-400 transition-colors" aria-label="Skicka e-post">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </a>
        </li>
        <li>
          <a
            href={FACEBOOK_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-500 hover:text-classic-400 transition-colors"
            aria-label="Facebook"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        </li>
      </ul>
    </div>
  </div>

</footer>
