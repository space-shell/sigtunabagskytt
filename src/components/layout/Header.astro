---
/**
 * Header.astro — Site-wide navigation header.
 * Mobile hamburger menu uses CSS <details> — zero JS required.
 */
import { NAV_ITEMS, CLUB_NAME } from '@utils/constants';

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-neutral-200 shadow-sm">
  <div class="container-content">
    <div class="flex items-center justify-between h-16">

      <!-- Logo / Club name -->
      <a
        href="/"
        class="flex items-center gap-3 font-display font-bold text-forest-700 hover:text-forest-600 transition-colors"
        aria-label={`${CLUB_NAME} – Startsida`}
      >
        <img
          src="/images/logo.svg"
          alt=""
          width="36"
          height="36"
          class="w-9 h-9"
          onerror="this.style.display='none'"
        />
        <span class="text-lg leading-tight">
          <span class="block">Sigtuna</span>
          <span class="block text-sm font-semibold text-bark-600">Bågskytteklubb</span>
        </span>
      </a>

      <!-- Desktop navigation -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Huvudnavigation">
        {NAV_ITEMS.map((item) => (
          <div class="relative group">
            {item.children ? (
              <>
                <!-- Parent item with dropdown -->
                <button
                  class:list={[
                    'flex items-center gap-1 px-3 py-2 rounded-md text-sm font-medium transition-colors',
                    isActive(item.href)
                      ? 'text-forest-700 bg-forest-50'
                      : 'text-neutral-700 hover:text-forest-700 hover:bg-neutral-50',
                  ]}
                  aria-expanded="false"
                  aria-haspopup="true"
                >
                  {item.label}
                  <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
                <!-- Dropdown -->
                <div class="absolute top-full left-0 min-w-[180px] py-1 mt-1 bg-white rounded-lg shadow-lg border border-neutral-200
                            opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150">
                  <a
                    href={item.href}
                    class:list={[
                      'block px-4 py-2 text-sm hover:bg-forest-50 hover:text-forest-700 transition-colors',
                      isActive(item.href) ? 'text-forest-700 font-medium' : 'text-neutral-700',
                    ]}
                  >
                    Översikt
                  </a>
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class:list={[
                        'block px-4 py-2 text-sm hover:bg-forest-50 hover:text-forest-700 transition-colors',
                        isActive(child.href) ? 'text-forest-700 font-medium' : 'text-neutral-700',
                      ]}
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </>
            ) : (
              <a
                href={item.href}
                class:list={[
                  'px-3 py-2 rounded-md text-sm font-medium transition-colors',
                  isActive(item.href)
                    ? 'text-forest-700 bg-forest-50'
                    : 'text-neutral-700 hover:text-forest-700 hover:bg-neutral-50',
                ]}
              >
                {item.label}
              </a>
            )}
          </div>
        ))}
      </nav>

      <!-- CTA button (desktop) -->
      <a href="/prova-pa/" class="hidden lg:inline-flex btn-primary text-sm">
        Prova på bågskyttning
      </a>

      <!-- Mobile menu toggle (CSS-only using <details>) -->
      <details class="lg:hidden group">
        <summary
          class="list-none flex items-center justify-center w-10 h-10 rounded-md text-neutral-700
                 hover:text-forest-700 hover:bg-neutral-100 transition-colors cursor-pointer"
          aria-label="Öppna meny"
        >
          <!-- Hamburger icon — hidden when open -->
          <svg class="w-6 h-6 group-open:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <!-- Close icon — shown when open -->
          <svg class="w-6 h-6 hidden group-open:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </summary>

        <!-- Mobile dropdown -->
        <div class="absolute left-0 right-0 top-16 bg-white border-b border-neutral-200 shadow-lg px-4 py-4 space-y-1">
          {NAV_ITEMS.map((item) => (
            <div>
              <a
                href={item.href}
                class:list={[
                  'block px-3 py-2.5 rounded-md text-base font-medium transition-colors',
                  isActive(item.href)
                    ? 'text-forest-700 bg-forest-50'
                    : 'text-neutral-800 hover:text-forest-700 hover:bg-neutral-50',
                ]}
              >
                {item.label}
              </a>
              {item.children?.map((child) => (
                <a
                  href={child.href}
                  class:list={[
                    'block px-6 py-2 text-sm rounded-md transition-colors',
                    isActive(child.href)
                      ? 'text-forest-700 bg-forest-50'
                      : 'text-neutral-600 hover:text-forest-700 hover:bg-neutral-50',
                  ]}
                >
                  {child.label}
                </a>
              ))}
            </div>
          ))}
          <div class="pt-2 border-t border-neutral-200">
            <a href="/prova-pa/" class="btn-primary w-full text-center">
              Prova på bågskyttning
            </a>
          </div>
        </div>
      </details>

    </div>
  </div>
</header>
