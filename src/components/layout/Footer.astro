---
import { CLUB_NAME, CLUB_EMAIL, CLUB_PHONE, CLUB_EMAIL_HREF, CLUB_PHONE_HREF, FACEBOOK_URL, CLUB_FOUNDED } from '@utils/constants';

const currentYear = new Date().getFullYear();
---

<footer class="bg-forest-900 text-white">
  <div class="container-content py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">

      <!-- Club info -->
      <div class="sm:col-span-2 lg:col-span-1">
        <h2 class="font-display font-bold text-lg text-white mb-3">
          {CLUB_NAME}
        </h2>
        <p class="text-forest-300 text-sm leading-relaxed">
          Grundad {CLUB_FOUNDED}. En bågskytteklubb för alla åldrar och nivåer i Märsta, Sigtuna.
        </p>
        <!-- Social links -->
        <div class="flex gap-3 mt-4">
          <a
            href={FACEBOOK_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="text-forest-400 hover:text-white transition-colors"
            aria-label="Facebook"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wider text-forest-400 mb-3">
          Navigation
        </h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="text-forest-200 hover:text-white transition-colors">Hem</a></li>
          <li><a href="/nyheter/" class="text-forest-200 hover:text-white transition-colors">Nyheter</a></li>
          <li><a href="/prova-pa/" class="text-forest-200 hover:text-white transition-colors">Prova på</a></li>
          <li><a href="/om-oss/" class="text-forest-200 hover:text-white transition-colors">Om oss</a></li>
          <li><a href="/om-oss/medlemskap/" class="text-forest-200 hover:text-white transition-colors">Medlemskap</a></li>
          <li><a href="/om-oss/traning/" class="text-forest-200 hover:text-white transition-colors">Träning</a></li>
          <li><a href="/om-oss/tavling/" class="text-forest-200 hover:text-white transition-colors">Tävling</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wider text-forest-400 mb-3">
          Kontakt
        </h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href={CLUB_EMAIL_HREF} class="text-forest-200 hover:text-white transition-colors break-all">
              {CLUB_EMAIL}
            </a>
          </li>
          <li>
            <a href={CLUB_PHONE_HREF} class="text-forest-200 hover:text-white transition-colors">
              {CLUB_PHONE}
            </a>
          </li>
          <li class="pt-1">
            <a href="/kontakt/" class="text-forest-200 hover:text-white transition-colors">
              Kontaktformulär →
            </a>
          </li>
          <li>
            <a href="/kontakt/hitta-till-oss/" class="text-forest-200 hover:text-white transition-colors">
              Hitta till oss →
            </a>
          </li>
        </ul>
      </div>

      <!-- Locations -->
      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wider text-forest-400 mb-3">
          Träningsplatser
        </h3>
        <div class="space-y-4 text-sm">
          <div>
            <p class="font-medium text-forest-200">Rävsta skjutbana (sommar)</p>
            <p class="text-forest-400">Rävstvägen 110, Märsta</p>
          </div>
          <div>
            <p class="font-medium text-forest-200">Eddaskolan (vinter)</p>
            <p class="text-forest-400">Märsta</p>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-forest-800">
    <div class="container-content py-4 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-forest-500">
      <p>&copy; {currentYear} {CLUB_NAME}. Alla rättigheter förbehållna.</p>
      <p>Grundad {CLUB_FOUNDED} i Märsta, Sigtuna</p>
    </div>
  </div>
</footer>
