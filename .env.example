# ─── Keystatic CMS (GitHub OAuth) ────────────────────────────────────────────
# Required in production. Create a GitHub OAuth App at:
# https://github.com/settings/developers
# Authorization callback URL: https://www.sigtunabagskytte.se/api/keystatic/github/oauth/callback
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
# A random 32+ character string used to sign session tokens
KEYSTATIC_SECRET=

# ─── Contact Form ─────────────────────────────────────────────────────────────
# Cloudflare Turnstile site key (public, safe to expose client-side)
PUBLIC_TURNSTILE_SITE_KEY=
# Cloudflare Turnstile secret key (server-side only, never expose)
TURNSTILE_SECRET_KEY=
# Email address to receive contact form submissions
CONTACT_EMAIL=sigtunabagskytte@gmail.com

# ─── Cloudflare R2 (local dev only — in production use Wrangler bindings) ─────
# Only needed for local development with `wrangler dev`
# Leave empty to skip image uploads locally
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ─── Optional analytics ───────────────────────────────────────────────────────
# Cloudflare Web Analytics beacon token (public, safe to expose)
# Find in Cloudflare dashboard → Analytics & Logs → Web Analytics
PUBLIC_CF_ANALYTICS_TOKEN=
